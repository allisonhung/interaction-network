# Public Supabase client config (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only key for AI route (do not expose in client code)
GEMINI_API_KEY=your-gemini-api-key

# Server-only key for admin invite flow (do not expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional explicit redirect URL used in invite emails (recommended for production)
SUPABASE_INVITE_REDIRECT_URL=https://your-app-domain.com/auth/callback

# Comma-separated list of emails allowed to approve signup requests
APPROVER_EMAILS=admin@example.com
